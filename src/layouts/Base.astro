---
import "../styles/global.css";
import { meta } from "../content/deck-data";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${meta.project} — ${meta.subtitle}`,
  description = "An institutional carve-out investment opportunity. CrestHaven Capital. Strictly Private & Confidential.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#051826" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    {/* Inline @font-face with base-relative URLs so fonts resolve correctly
        on any sub-path deployment (GitHub Pages, etc.). CSS url("/fonts/...")
        is not rewritten by Vite when the path starts with "/", so we inject
        these declarations dynamically using the runtime BASE_URL. */}
    <style set:html={`
      @font-face {
        font-family: "Roboto Slab Variable";
        src: url("${base}fonts/RobotoSlab-Variable.woff2") format("woff2-variations");
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "DM Sans Variable";
        src: url("${base}fonts/DMSans-Variable.woff2") format("woff2-variations");
        font-weight: 100 1000;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "DM Sans Variable";
        src: url("${base}fonts/DMSans-Variable-Italic.woff2") format("woff2-variations");
        font-weight: 100 1000;
        font-style: italic;
        font-display: swap;
      }
    `} />

    {/* Preload critical-path faces — body (DM Sans) and heading (Roboto Slab).
        crossorigin is required for woff2 preload to be honored. */}
    <link
      rel="preload"
      href={`${base}fonts/DMSans-Variable.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${base}fonts/RobotoSlab-Variable.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="antialiased selection:bg-accent selection:text-bone">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded focus:bg-accent focus:px-3 focus:py-2 focus:text-bone focus:font-sans focus:text-xs focus:uppercase focus:tracking-label"
    >
      Skip to content
    </a>

    <Nav />
    <main id="main"><slot /></main>

    <script>
      import "../scripts/animations.ts";
    </script>
  </body>
</html>
