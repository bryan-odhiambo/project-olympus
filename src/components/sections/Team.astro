---
import { principals, team } from "../../content/deck-data";
---

<section
  data-team
  class="relative w-full bg-ink-0 py-24 md:py-32"
  aria-label="The Team — CrestHaven Capital leadership"
>
  <div class="shell">
    {/* Header */}
    <div class="mb-20 grid grid-cols-1 gap-6 md:mb-28 md:grid-cols-12">
      <div class="md:col-span-7">
        <span class="eyebrow">IX · The Team</span>
        <h2 class="mt-4 max-w-[18ch] font-serif text-headline tracking-tightest">
          The operators behind the platform.
        </h2>
      </div>
      <p class="max-w-prose-tight text-sm text-bone-muted md:col-span-5 md:self-end">
        CrestHaven Capital is led by a team that has executed $100B+ in
        regulated transactions, built and exited award-winning aerospace and
        defense platforms, and serves at the highest levels of federal advisory.
      </p>
    </div>

    {/* Principal cards — vertical editorial stack */}
    <div class="flex flex-col">
      {principals.map((p, i) => (
        <article
          data-tilt
          data-tilt-max="2"
          class="reveal grid grid-cols-1 gap-8 border-t border-ink-300 py-14 md:grid-cols-12 md:gap-10 md:py-20"
          aria-labelledby={`principal-${i}`}
        >
          {/* Index + role */}
          <div class="md:col-span-3">
            <span class="font-sans text-[10px] uppercase tracking-label text-bone-dim">
              {String(i + 1).padStart(2, "0")} · Principal
            </span>
            <div
              id={`principal-${i}`}
              class="mt-6 font-serif text-3xl text-bone leading-[1.05] md:text-4xl"
            >
              {p.name}
            </div>
            <div class="mt-4 flex flex-col gap-1">
              <span class="font-sans text-[10px] uppercase tracking-label text-accent">
                {p.title}
              </span>
              <span class="text-xs italic text-bone-muted">{p.sub}</span>
            </div>
          </div>

          {/* Bio paragraphs */}
          <div class="md:col-span-6">
            <div class="flex flex-col gap-5">
              {p.paragraphs.map((para) => (
                <p class="text-base text-bone leading-relaxed md:text-[17px]">
                  {para}
                </p>
              ))}
            </div>
          </div>

          {/* Credentials */}
          <div class="md:col-span-3">
            <div class="border-l border-ink-300 pl-5">
              <span class="font-sans text-[10px] uppercase tracking-label text-bone-muted">
                Credentials
              </span>
              <p class="mt-3 text-xs text-bone-muted leading-relaxed">
                {p.credentials}
              </p>
            </div>
          </div>
        </article>
      ))}
      <div class="border-t border-ink-300"></div>
    </div>

    {/* Wider team — 4-up grid */}
    <div class="mt-24">
      <div class="mb-10 flex items-baseline justify-between">
        <h3 class="font-serif text-2xl text-bone md:text-3xl">
          The Wider Team
        </h3>
        <span class="hidden font-sans text-[10px] uppercase tracking-label text-bone-dim md:inline">
          Operating, legal, finance
        </span>
      </div>

      <div class="grid grid-cols-1 gap-px overflow-hidden border border-ink-300 bg-ink-300 sm:grid-cols-2 lg:grid-cols-4">
        {team.map((member) => (
          <article data-tilt data-tilt-max="5" class="flex flex-col gap-4 bg-ink-50 p-6 md:p-7">
            <span class="font-serif text-xl text-bone md:text-2xl">
              {member.name}
            </span>
            <span class="font-sans text-[10px] uppercase tracking-label text-accent">
              {member.role}
            </span>
            <p class="mt-1 text-xs text-bone-muted leading-relaxed">
              {member.detail}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
