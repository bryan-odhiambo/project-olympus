---
import { phases } from "../../content/deck-data";
---

<section
  data-phases
  class="relative w-full bg-ink-0 py-8 md:py-10"
  aria-label="Three-Phase Growth Architecture"
>
  <div class="shell">
    {/* Header */}
    <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-12">
      <div class="md:col-span-7">
        <span class="eyebrow">IV · Value Creation Framework</span>
        <h2 class="mt-4 max-w-[20ch] font-serif text-headline tracking-tightest">
          Three phases. One platform.
        </h2>
      </div>
      <p class="max-w-prose-tight text-sm text-bone-muted md:col-span-5 md:self-end">
        A staged growth architecture: protect the contracted base,
        unlock margin through operational discipline, then compound on
        secular tailwinds in a $124B+ MRO market.
      </p>
    </div>

    {/* Vertical staggered phases */}
    <div class="flex flex-col">
      {phases.map((phase) => (
        <article
          class="reveal relative grid grid-cols-1 gap-6 border-t border-ink-300 py-5 md:grid-cols-12 md:gap-8 md:py-7"
          aria-labelledby={`phase-${phase.number}`}
        >
          {/* Big phase numeral */}
          <div class="md:col-span-3">
            <div
              class="font-sans font-semibold text-[3.5rem] leading-none tracking-tightest text-accent md:text-[4.5rem]"
              aria-hidden="true"
              style="font-feature-settings: 'lnum';"
            >
              {phase.number}
            </div>
            <div class="mt-3 flex flex-col gap-1">
              <span class="font-sans text-[10px] uppercase tracking-label text-bone-muted">
                Phase
              </span>
              <span
                id={`phase-${phase.number}`}
                class="font-serif text-2xl text-bone md:text-3xl"
              >
                {phase.name}
              </span>
              <span class="text-sm italic text-bone-muted">
                {phase.headline}
              </span>
            </div>
          </div>

          {/* Metrics — horizontal row */}
          <div class="md:col-span-4">
            <ul class="flex flex-row gap-6">
              {phase.metrics.map((m) => (
                <li class="border-l border-ink-300 pl-4">
                  <div class="stat-number text-xl text-bone md:text-2xl">{m.value}</div>
                  <div class="mt-1 font-sans text-[10px] uppercase tracking-label text-bone-muted">
                    {m.label}
                  </div>
                </li>
              ))}
            </ul>
          </div>

          {/* Bullets */}
          <div class="md:col-span-5">
            <ul class="flex flex-col gap-4 md:pl-6">
              {phase.bullets.map((b) => (
                <li class="flex items-start gap-3 text-bone leading-relaxed">
                  <span
                    class="mt-2 inline-block h-px w-4 shrink-0 bg-accent"
                    aria-hidden="true"
                  ></span>
                  <span class="text-base">{b}</span>
                </li>
              ))}
            </ul>
          </div>

        </article>
      ))}
    </div>

    {/* Caption */}
    <p class="mt-6 w-full font-sans text-[11px] uppercase leading-relaxed tracking-label text-bone-dim">
      Market data: Aerospace engineering services 5.8% CAGR to $81.7B; MRO market $103.9B → $124.1B. Source: Stephens analysis.
    </p>
  </div>
</section>
