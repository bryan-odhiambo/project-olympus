---
import { meta, contact } from "../../content/deck-data";
---

<section
  data-close
  class="relative w-full overflow-hidden bg-ink-0 pt-16 pb-10"
  aria-label="Close — closing statement and contact"
>
  {/* Top frame */}
  <div class="shell flex items-center justify-between">
    <span class="eyebrow">IX · Close</span>
    <span class="eyebrow hidden md:inline">{meta.classification}</span>
  </div>

  {/* Closing statement */}
  <div class="shell mt-12">
    <div class="reveal mx-auto max-w-3xl text-center">
      <p
        class="font-serif tracking-tightest text-bone leading-[1.05]"
        style="font-size: clamp(2rem, 4.5vw, 3.75rem);"
      >
        {meta.closingStatement.split("disciplined entry multiple")[0]}<span class="text-accent"
          >disciplined entry multiple.</span
        >
      </p>
    </div>
  </div>

  {/* Contact rail */}
  <div class="shell mt-14">
    <div class="grid grid-cols-1 gap-10 border-t border-ink-300 pt-10 md:grid-cols-12">
      <div class="md:col-span-5">
        <span class="eyebrow text-bone-dim">CrestHaven Capital</span>
        <p class="mt-3 font-serif text-xl text-bone md:text-2xl">
          {contact.address}
        </p>
      </div>
      <div class="md:col-span-4">
        <span class="eyebrow text-bone-dim">Direct</span>
        <a
          href={`mailto:${contact.email}`}
          class="mt-3 block font-serif text-xl text-accent transition-colors hover:text-accent-glow md:text-2xl"
        >
          {contact.email}
        </a>
      </div>
      <div class="md:col-span-3">
        <span class="eyebrow text-bone-dim">Web</span>
        <p class="mt-3 font-sans text-base text-bone-muted">
          {contact.url}
        </p>
      </div>
    </div>

    {/* Footer — confidentiality */}
    <p class="mt-6 font-sans text-[10px] uppercase leading-relaxed tracking-label text-bone-dim">
      {meta.classification}. For qualified institutional and accredited investors only.
      Not an offer to sell or solicitation to buy securities.
      &copy; {new Date().getFullYear()} CrestHaven Capital. All rights reserved.
    </p>
  </div>
</section>
