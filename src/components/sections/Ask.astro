---
import { ask } from "../../content/deck-data";
---

<section
  data-ask
  class="relative flex min-h-screen w-full items-center overflow-hidden bg-ink-0 py-16 md:py-20"
  aria-label="The Ask"
>
  <div class="shell relative w-full">
    <div class="reveal">
      <span class="eyebrow block">VIII · The Ask</span>

      {/* Headline — "We are seeking / $100M in / structured capital." */}
      <h2 class="mt-8 font-serif text-[clamp(3rem,8vw,7rem)] tracking-tightest leading-[0.95]">
        We are seeking
        <span class="block">
          <span data-ask-amount class="font-sans nums font-semibold tracking-tightest text-accent">$0M</span>{" "}in
        </span>
        <span class="block">structured capital.</span>
      </h2>

      <p class="mt-10 max-w-[44ch] text-sm text-bone-muted leading-relaxed md:text-base">
        {ask.body}
      </p>

      {/* Composability strip — full shell width */}
      <div class="mt-12 grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-ink-300 bg-ink-300 md:grid-cols-4">
        {[
          "Senior Debt",
          "Mezzanine",
          "Preferred Equity",
          "Common Equity",
        ].map((label) => (
          <div class="flex flex-col items-start gap-2 bg-ink-50 px-4 py-4">
            <span class="block h-px w-6 bg-accent" aria-hidden="true"></span>
            <span class="font-sans text-[11px] uppercase tracking-label text-bone">
              {label}
            </span>
          </div>
        ))}
      </div>

      <p class="mt-8 max-w-[44ch] text-xs text-bone-dim leading-relaxed">
        Or any combination thereof. Capital stack designed to optimize cost of
        capital and investor control.
      </p>
    </div>
  </div>
</section>
